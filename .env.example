# ============================================================
# Clinic Platform — Environment Template
# Copy to app/.env.local and fill. NEVER commit real values.
#
# PUBLIC vars (NEXT_PUBLIC_*) are embedded in the browser bundle
# and must NEVER contain secrets or internal URLs.
# Everything else is server-only (BFF adapter).
# ============================================================

# ---------- Public (browser-safe) ----------
NEXT_PUBLIC_APP_ENV=local              # local | staging | production
NEXT_PUBLIC_APP_NAME="Demo Medical Clinic"

# ---------- Server-only: mode ----------
APP_ENV=local                          # local | staging | production
USE_MOCK_DATA=true                     # true = MockProvider (no OpenEMR needed)
ALLOW_WRITES=true                      # safety gate: set false to block all writes to OpenEMR

# ---------- Server-only: platform database (identity, bookings, wallet, payments, audit) ----------
# Demo: SQLite. Production: Postgres connection string.
ADAPTER_DATABASE_URL="file:./dev.db"

# ---------- Server-only: platform auth ----------
AUTH_SESSION_SECRET=change-me-32-chars-min
OTP_MODE=mock                          # mock (code 123456) | sms (Phase 3)

# ---------- Server-only: payments ----------
PAYMENTS_PROVIDER=mock                 # mock | (stripe|tap|hyperpay — Phase 3)

# ---------- Server-only: OpenEMR connection (ignored when USE_MOCK_DATA=true) ----------
# Local Docker default shown; XAMPP would be http://localhost/openemr
OPENEMR_BASE_URL=https://localhost:9300
OPENEMR_API_URL=https://localhost:9300/apis/default/api
OPENEMR_FHIR_URL=https://localhost:9300/apis/default/fhir
OPENEMR_OAUTH_TOKEN_URL=https://localhost:9300/oauth2/default/token
OPENEMR_OAUTH_REGISTRATION_URL=https://localhost:9300/oauth2/default/registration

# OAuth2 client (from dynamic registration). Server-only. Demo uses password grant
# (enable in OpenEMR: Administration → Config → Connectors + globals password-grant setting).
# PRODUCTION MUST switch to client_credentials + JWKS — see DECISION_LOG D4.
OPENEMR_GRANT_TYPE=password            # password (demo) | client_credentials (production)
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
# Demo-grant service user (least-privileged API user created in OpenEMR):
OPENEMR_API_USERNAME=
OPENEMR_API_PASSWORD=
# Minimal scopes for our integration:
OPENEMR_SCOPES="openid offline_access api:oemr user/patient.cruds user/appointment.cruds user/practitioner.rs user/facility.rs user/encounter.rs user/document.crs api:fhir user/Condition.rs user/AllergyIntolerance.rs user/MedicationRequest.rs user/Observation.rs user/DocumentReference.rs"

# ============================================================
# Example overrides per environment (do not uncomment here;
# set in the deployment environment instead)
# ============================================================
# --- staging ---
# APP_ENV=staging
# USE_MOCK_DATA=false
# ALLOW_WRITES=true
# OPENEMR_BASE_URL=https://staging-openemr.example-clinic.com
# OPENEMR_API_URL=https://staging-openemr.example-clinic.com/apis/default/api
# OPENEMR_FHIR_URL=https://staging-openemr.example-clinic.com/apis/default/fhir
# OPENEMR_OAUTH_TOKEN_URL=https://staging-openemr.example-clinic.com/oauth2/default/token
# ADAPTER_DATABASE_URL=postgresql://user:pass@host:5432/clinic_staging
#
# --- production ---
# APP_ENV=production
# USE_MOCK_DATA=false
# OPENEMR_GRANT_TYPE=client_credentials
# (client_credentials requires registered JWKS; OPENEMR_API_USERNAME/PASSWORD unused)
