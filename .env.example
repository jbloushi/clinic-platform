# ============================================================
# Clinic Platform — Environment Template
# Copy to app/.env.local (runtime) and app/.env (Prisma CLI + seed) and fill.
# NEVER commit real values — .env, .env.local and .secrets/ are gitignored.
#
# PUBLIC vars (NEXT_PUBLIC_*) are embedded in the browser bundle
# and must NEVER contain secrets or internal URLs.
# Everything else is server-only (BFF adapter).
#
# Two files matter:
#   app/.env.local  — read by Next.js at runtime (all vars below)
#   app/.env        — read by the Prisma CLI + seed scripts; needs at least
#                     ADAPTER_DATABASE_URL, OPENEMR_DB_URL, and (on the VPS)
#                     SEED_FACILITY_ID / SEED_OFFICE_VISIT_CATID.
# ============================================================

# ---------- Public (browser-safe) ----------
NEXT_PUBLIC_APP_ENV=local              # local | staging | production
NEXT_PUBLIC_APP_NAME="Demo Medical Clinic"

# ---------- Server-only: mode ----------
APP_ENV=local                          # local | staging | production
USE_MOCK_DATA=false                    # true = MockProvider (no OpenEMR needed)
ALLOW_WRITES=true                      # safety gate: false blocks all writes to OpenEMR

# ---------- Server-only: platform database (identity, bookings, wallet, payments, audit) ----------
# MySQL/MariaDB (Prisma provider = "mysql"). Local dev uses the XAMPP MariaDB
# on 3307; the VPS uses a dedicated schema on the aaPanel MariaDB, local to the
# app server. Create the schema first: CREATE DATABASE clinic_platform;
ADAPTER_DATABASE_URL="mysql://root@127.0.0.1:3307/clinic_platform"

# Direct MariaDB connection to the OpenEMR install — used ONLY by the emr-db.ts
# shim to compensate for OpenEMR 8.0 REST gaps (authorize/activate a
# practitioner) and by the seed to write demo data. Point at OpenEMR's own DB.
OPENEMR_DB_URL="mysql://root@127.0.0.1:3307/openemr"

# ---------- Server-only: platform auth ----------
AUTH_SESSION_SECRET=change-me-32-chars-min
OTP_MODE=mock                          # mock (code 123456) | sms (not implemented) | whatsapp (Chatwoot)

# ---------- Server-only: WhatsApp OTP via Chatwoot (only when OTP_MODE=whatsapp) ----------
# Requires a Chatwoot inbox wired to a WhatsApp channel AND a Meta-approved
# Authentication-category template. Leave blank for mock. See lib/chatwoot.ts.
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_WHATSAPP_INBOX_ID=
CHATWOOT_OTP_TEMPLATE_NAME=
CHATWOOT_OTP_TEMPLATE_LANG=en

# ---------- Server-only: payments ----------
PAYMENTS_PROVIDER=mock                 # mock | (stripe|tap|hyperpay — future)

# ---------- Seed overrides (Prisma CLI / seed scripts; read from app/.env) ----------
# The demo seed writes appointments/encounters against these OpenEMR IDs.
# Defaults match a stock OpenEMR install (facility 3 = "Your Clinic Name",
# category 5 = "Office Visit"). VERIFY on the target OpenEMR before seeding —
# a fresh install on another host may assign different IDs.
# SEED_FACILITY_ID=3
# SEED_OFFICE_VISIT_CATID=5

# ---------- Server-only: OpenEMR connection (ignored when USE_MOCK_DATA=true) ----------
# Local XAMPP install (this repo's default): http://localhost/openemr
OPENEMR_BASE_URL=http://localhost/openemr
OPENEMR_API_URL=http://localhost/openemr/apis/default/api
OPENEMR_FHIR_URL=http://localhost/openemr/apis/default/fhir
OPENEMR_OAUTH_TOKEN_URL=http://localhost/openemr/oauth2/default/token
OPENEMR_OAUTH_REGISTRATION_URL=http://localhost/openemr/oauth2/default/registration

# OAuth2 client (from dynamic registration). Server-only. Demo uses password grant
# (enable in OpenEMR globals: oauth_password_grant). Newly registered clients are
# DISABLED by default — enable in Admin → System → API Clients.
# PRODUCTION MUST switch to client_credentials + JWKS — see DECISION_LOG D4.
OPENEMR_GRANT_TYPE=password            # password (demo) | client_credentials (production)
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_API_USERNAME=
OPENEMR_API_PASSWORD=
OPENEMR_SCOPES="openid offline_access api:oemr user/patient.cruds user/appointment.cruds user/practitioner.cruds user/user.cruds user/facility.rs user/encounter.rs api:fhir user/Patient.rs user/Practitioner.rs user/Appointment.rs user/Encounter.rs user/Condition.rs user/AllergyIntolerance.rs user/MedicationRequest.rs user/Observation.rs user/DocumentReference.rs"

# ============================================================
# VPS demo override (book.mawthook.io → clinic.mawthook.io)
# Set these in app/.env.local on the server; do not uncomment here.
# ============================================================
# NEXT_PUBLIC_APP_ENV=production
# APP_ENV=production
# USE_MOCK_DATA=false
# ALLOW_WRITES=true
# OTP_MODE=mock                        # 123456 works for any visitor (demo only!)
# AUTH_SESSION_SECRET=<32+ random chars — generate fresh, do not reuse the demo value>
# ADAPTER_DATABASE_URL=mysql://clinic:<pass>@127.0.0.1:3306/clinic_platform
# OPENEMR_DB_URL=mysql://<openemr_user>:<pass>@127.0.0.1:3306/<openemr_db>
# OPENEMR_BASE_URL=https://clinic.mawthook.io
# OPENEMR_API_URL=https://clinic.mawthook.io/apis/default/api
# OPENEMR_FHIR_URL=https://clinic.mawthook.io/apis/default/fhir
# OPENEMR_OAUTH_TOKEN_URL=https://clinic.mawthook.io/oauth2/default/token
# OPENEMR_CLIENT_ID / OPENEMR_CLIENT_SECRET / OPENEMR_API_USERNAME / OPENEMR_API_PASSWORD  = the VPS OpenEMR's own client + service user
# SEED_FACILITY_ID / SEED_OFFICE_VISIT_CATID  = the VPS OpenEMR's actual IDs (verify first)
